# Copy to `.env.local` for local development (never commit real secrets).

# Firebase Admin (server): paste full JSON for a service account with Firestore access
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account", "...":"..."}

# Firebase Web (client) — from Firebase console Project settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Exact `storageBucket` from the same Firebase web config (e.g. myproj.firebasestorage.app).
# Server uploads use this if FIREBASE_STORAGE_BUCKET is unset. Omit only if you rely on inference.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Optional override for Admin Storage (same value as storageBucket / NEXT_PUBLIC_* above).
# Use for legacy *.appspot.com buckets if inference picks the wrong hostname.
FIREBASE_STORAGE_BUCKET=

# Public site URL (no trailing slash). Used for metadataBase, canonical/OG, sitemap,
# password-reset continueUrl. Must match a domain in Firebase Auth → Settings →
# Authorized domains. Vercel previews may use NEXT_PUBLIC_APP_URL or rely on VERCEL_URL.
NEXT_PUBLIC_APP_URL=https://wellnessparistx.com

# SendGrid (server) — FROM must match a verified Single Sender in SendGrid.
# Preferred: SENDGRID_API_KEY and SENDGRID_FROM_EMAIL.
# Also accepted: SEND_GRID or send_grid; sendgridfromemail or SENDGRIDFROMEMAIL (Vercel naming typos).
# FROM must be a single email only (no quotes, no JSON, no API key — put the key in SENDGRID_API_KEY only).
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=russell_forsyth_1992@outlook.com
OFFICE_NOTIFICATION_EMAIL=

# Optional: rotate occasionally; used to hash IPs for rate limiting
RATE_LIMIT_SALT=change-me

# Vercel Cron (production): required when VERCEL_ENV=production so /api/cron/* accepts
# scheduled jobs. Set the same value in Vercel → Project → Settings → Environment Variables.
# Vercel injects Authorization: Bearer <CRON_SECRET> on cron invocations when this is set.
CRON_SECRET=

# One-time bootstrap: set a long random secret, deploy, sign in, POST bootstrap, then remove
ADMIN_BOOTSTRAP_SECRET=

# Square (server) — for payment links via the admin dashboard.
# Create an application at https://developer.squareup.com and paste your access token.
# SQUARE_ENVIRONMENT: "sandbox" for testing, "production" for real charges.
# SQUARE_LOCATION_ID: find in Square Dashboard → Locations.
# SQUARE_WEBHOOK_SIGNATURE_KEY: from Square Dashboard → Webhooks → Signature key.
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Public booking prepay (optional): after a patient books one visit (no recurring series),
# create a Square checkout link when any of these resolve to a valid cent amount (>= 50).
# Prefer per service + duration; otherwise set a single fallback for all combinations.
# PUBLIC_BOOKING_PREPAY_MASSAGE_30_CENTS=6000
# PUBLIC_BOOKING_PREPAY_MASSAGE_60_CENTS=9500
# PUBLIC_BOOKING_PREPAY_CHIROPRACTIC_30_CENTS=5000
# PUBLIC_BOOKING_PREPAY_CHIROPRACTIC_60_CENTS=7500
# PUBLIC_BOOKING_PREPAY_CENTS=8000

# Twilio (server) — for SMS appointment reminders and payment link delivery.
# Create an account at https://www.twilio.com and get your credentials.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Analytics & marketing (all optional) ---

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). When set, GA loads automatically.
NEXT_PUBLIC_GA_ID=

# Google Tag Manager container ID (GTM-XXXXXX). When set, GTM loads automatically.
NEXT_PUBLIC_GTM_ID=

# --- Local SEO / sameAs links (optional; used in JSON-LD and CTAs) ---

# Google Business Profile review URLs (paste each location's `…/review/...` URL)
NEXT_PUBLIC_GBP_PARIS_URL=
NEXT_PUBLIC_GBP_SS_URL=

# Social profiles (URLs)
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_YELP_URL=

# --- Vercel CLI (local deploy) & GitHub Actions ---
# Local: run `npm run vercel:login` once on this machine, then `npm run vercel:link` in this repo,
# then `npm run deploy:vercel`. Tokens are stored in your user profile (not in the repo).
#
# Non-interactive (CI or scripting): create a token at https://vercel.com/account/tokens then set:
#   VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID
# Org + project IDs: Vercel → your project → Settings → General.
# GitHub: add the same three names as repository secrets and run the "Vercel Production Deploy" workflow.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
