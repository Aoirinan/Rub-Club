# Copy to `.env.local` for local development (never commit real secrets).

# Firebase Admin (server): paste full JSON for a service account with Firestore access
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account", "...":"..."}

# Firebase Web (client) — from Firebase console Project settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# SendGrid (server)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
OFFICE_NOTIFICATION_EMAIL=

# Optional: rotate occasionally; used to hash IPs for rate limiting
RATE_LIMIT_SALT=change-me

# One-time bootstrap: set a long random secret, deploy, sign in, POST bootstrap, then remove
ADMIN_BOOTSTRAP_SECRET=
